@base <https://sparql.volunteeringdata.io/sparql>.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix : <https://ns.volunteeringdata.io/>.
@prefix dc: <http://purl.org/dc/terms/>.
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#>.
@prefix geosparql: <http://www.opengis.net/ont/geosparql#>.
@prefix id: <https://id.volunteeringdata.io/>.
@prefix og: <http://ogp.me/ns#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix vann: <http://purl.org/vocab/vann/>.
@prefix vcard: <http://www.w3.org/2006/vcard/ns#>.

<https://ns.volunteeringdata.io/> dc:description "Defines a vocabulary to describe volunteering activities, volunteer-involving organisations and volunteering management systems."@en;
                                  dc:issued "2025-11-20"^^xsd:date;
                                  dc:title "Volunteering and Social Action Ontology"@en;
                                  vann:preferredNamespacePrefix "volunteering";
                                  vann:preferredNamespaceUri "https://ns.volunteeringdata.io/"^^xsd:anyURI;
                                  a owl:Ontology;
                                  rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                                  rdfs:label "Volunteering and Social Action Ontology"@en;
                                  rdfs:seeAlso <https://standard.volunteeringdata.io/ontology/>;
                                  owl:versionIRI <https://ns.volunteeringdata.io/>;
                                  owl:versionInfo "2026-03-12".
:Accessibility a skos:Concept;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               skos:definition "Any accessibility information related to volunteering activities."@en;
               skos:prefLabel "Accessibility"@en;
               skos:topConceptOf :Taxonomy.
:ActiveListening a skos:Concept;
                 rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                 skos:broader :Communication;
                 skos:definition "Ability to listen attentively and respond appropriately."@en;
                 skos:prefLabel "Active listening"@en.
:Activity dc:description "Volunteering Activity"@en;
          a owl:Class;
          rdfs:comment "Any kind of activity that involves volunteers."@en;
          rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
          rdfs:label "Activity"@en.
:AgeRequirements a skos:Concept;
                 rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                 skos:broader :Accessibility;
                 skos:definition "Any information regarding specific ages or ranges of ages required or disallowed from a activity.";
                 skos:inScheme :Taxonomy;
                 skos:prefLabel "Age Requirements".
:AnimalWelfare a skos:Concept;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               skos:altLabel "Mammals"@en,
                             "Creatures"@en,
                             "Pets"@en,
                             "Wildlife"@en;
               skos:broader :Cause;
               skos:definition "Volunteering focused on the protection, care, and welfare of animals, including wildlife conservation, pet support, and creature advocacy."@en;
               skos:prefLabel "Animal Welfare"@en.
:AntiPoverty a skos:Concept;
             rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
             skos:altLabel "Tackling Poverty"@en,
                           "Poverty Reduction"@en;
             skos:broader :Cause;
             skos:definition "Volunteering activities aimed at reducing poverty, supporting low-income households, and promoting economic empowerment."@en;
             skos:prefLabel "Anti-Poverty"@en.
:ArtsAndCulture a skos:Concept;
                rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                skos:altLabel "Crafts"@en,
                              "Graphic Arts"@en,
                              "Dance"@en,
                              "Theatre"@en,
                              "Music"@en,
                              "Humanities"@en,
                              "Society"@en,
                              "Culture"@en;
                skos:broader :Cause;
                skos:definition "Volunteering in artistic and cultural domains including music, theatre, dance, visual arts, crafts, and heritage preservation."@en;
                skos:prefLabel "Arts and Culture"@en.
:AssetsEquipment a skos:Concept;
                 rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                 skos:broader :Requirement;
                 skos:definition "Physical items, equipment, vehicles, and assets needed for volunteering activities."@en;
                 skos:prefLabel "Assets & Equipment"@en.
:BasicEquipmentUse a skos:Concept;
                   rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                   skos:broader :PracticalAndOperational;
                   skos:definition "Ability to use basic equipment such as sandbags, barriers, and hand tools."@en;
                   skos:prefLabel "Use of basic equipment (sandbags, barriers, tools)"@en.
:BasicFirstAid a skos:Concept;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               skos:broader :SafetyAndEmergencyAwareness;
               skos:definition "Basic knowledge of first aid procedures and techniques."@en;
               skos:prefLabel "Basic first aid knowledge"@en.
:BasicITSkills a skos:Concept;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               skos:broader :DigitalAndTechnology;
               skos:definition "Fundamental computer and information technology skills."@en;
               skos:prefLabel "Basic IT skills"@en.
:BasicRecordKeeping a skos:Concept;
                    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                    skos:broader :PracticalAndOperational;
                    skos:definition "Ability to maintain basic records and documentation."@en;
                    skos:prefLabel "Basic record keeping"@en.
:BasicSafeguarding a skos:Concept;
                   rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                   skos:broader :SafetyAndEmergencyAwareness;
                   skos:definition "Understanding of basic safeguarding principles and practices."@en;
                   skos:prefLabel "Basic safeguarding knowledge"@en.
:BicyclesCargoBikes a skos:Concept;
                    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                    skos:broader :TransportMobilityAssets;
                    skos:prefLabel "Access to bicycles or cargo bikes"@en.
:Boat a skos:Concept;
      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
      skos:broader :TransportMobilityAssets;
      skos:prefLabel "Boat"@en.
:BuildingAccessibilityFeatures a skos:Concept;
                               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                               skos:broader :Accessibility;
                               skos:definition "Any information on building accessibility features for mobility aid users and accessible gender, faith, etc. rooms.";
                               skos:inScheme :PhysicalAccessibility;
                               skos:prefLabel "Building Accessibility Features".
:CalmnessUnderPressure a skos:Concept;
                       rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                       skos:broader :PersonalAndInterpersonal;
                       skos:definition "Ability to remain calm and composed in stressful or high-pressure situations."@en;
                       skos:prefLabel "Calmness under pressure"@en.
:Care a skos:Concept;
      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
      skos:altLabel "Home Carers"@en,
                    "Live in carers"@en,
                    "Guardians"@en,
                    "Caregivers"@en,
                    "Carers"@en,
                    "Social Care"@en,
                    "Addiction Support"@en,
                    "Counselling Support"@en,
                    "Care Providers"@en,
                    "Care Services"@en;
      skos:broader :Cause;
      skos:definition "Volunteering providing care services, support to carers, counselling, and social care assistance."@en;
      skos:prefLabel "Care"@en.
:CareProfessionals a skos:Concept;
                   rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                   skos:broader :Accessibility;
                   skos:definition "Any accommodations available for volunteers assisted by care professionals.";
                   skos:inScheme :PhysicalAccessibility;
                   skos:prefLabel "Care Professionals".
:Cause a skos:Concept;
       rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
       skos:definition "Any charitable cause related to volunteering activities."@en;
       skos:prefLabel "Cause"@en;
       skos:topConceptOf :Taxonomy.
:CivilRights a skos:Concept;
             rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
             skos:altLabel "Justice"@en,
                           "Equality"@en,
                           "Citizens Rights"@en,
                           "Human Rights"@en;
             skos:broader :Cause;
             skos:definition "Volunteering promoting human rights, civil liberties, equality, justice, and citizen empowerment."@en;
             skos:prefLabel "Civil Rights"@en.
:ClearSpokenCommunication a skos:Concept;
                          rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                          skos:broader :Communication;
                          skos:definition "Ability to speak clearly and convey information effectively."@en;
                          skos:prefLabel "Clear spoken communication"@en.
:Communication a skos:Concept;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               skos:broader :Skill;
               skos:definition "Skills related to verbal, written, and interpersonal communication in volunteering contexts."@en;
               skos:prefLabel "Communication"@en.
:Community a skos:Concept;
           rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
           skos:altLabel "Local Public"@en,
                         "Society"@en,
                         "Community groups"@en;
           skos:broader :Cause;
           skos:definition "Volunteering supporting community development, local initiatives, and strengthening of community groups."@en;
           skos:prefLabel "Community"@en.
:CommunityEnvironmentKnowledge a skos:Concept;
                               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                               skos:broader :Requirement;
                               skos:definition "Knowledge and awareness of local community, environment, and support systems."@en;
                               skos:prefLabel "Community & Environment Knowledge"@en.
:ConflictDeescalation a skos:Concept;
                      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                      skos:broader :PersonalAndInterpersonal;
                      skos:definition "Ability to reduce tension and resolve conflicts calmly."@en;
                      skos:prefLabel "Conflict de-escalation"@en.
:CooperativeWork a skos:Concept;
                 rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                 skos:broader :TeamworkAndLeadership;
                 skos:definition "Ability to collaborate and work effectively as part of a team."@en;
                 skos:prefLabel "Ability to work cooperatively"@en.
:CrimeExOffenders a skos:Concept;
                  rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                  skos:altLabel "Prisons"@en,
                                "Criminal Justice System"@en;
                  skos:broader :CrimeSafety;
                  skos:definition "Volunteering supporting offenders, ex-offenders, rehabilitation programmes, and the criminal justice system."@en;
                  skos:prefLabel "Crime & ex-offenders"@en.
:CrimeSafety a skos:Concept;
             rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
             skos:altLabel "Wrongdoing"@en,
                           "Offences"@en,
                           "Security"@en,
                           "Protection"@en;
             skos:broader :Cause;
             skos:definition "Volunteering supporting crime prevention, public safety, victim support, and protection services."@en;
             skos:prefLabel "Crime / Safety"@en.
:CrowdQueueManagement a skos:Concept;
                      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                      skos:broader :PracticalAndOperational;
                      skos:definition "Ability to manage crowds and queues safely and efficiently."@en;
                      skos:prefLabel "Crowd/queue management"@en.
:CulturalSensitivity a skos:Concept;
                     rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                     skos:broader :PersonalAndInterpersonal;
                     skos:definition "Awareness of and respect for cultural differences and diversity."@en;
                     skos:prefLabel "Cultural sensitivity"@en.
:DBSCheck a skos:Concept;
          rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
          skos:broader :Legal;
          skos:prefLabel "DBS Check"@en.
:DataEntryAndReporting a skos:Concept;
                       rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                       skos:broader :DigitalAndTechnology;
                       skos:definition "Ability to perform simple data entry and produce basic reports."@en;
                       skos:prefLabel "Simple data entry and reporting"@en.
:DevelopmentEmergencyRelief a skos:Concept;
                            rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                            skos:altLabel "Crisis"@en,
                                          "Tragedy"@en,
                                          "Accidents"@en,
                                          "Urgent problem"@en,
                                          "Natural Disasters"@en,
                                          "Responders"@en,
                                          "Rescue Services"@en,
                                          "Emergency Support"@en,
                                          "Emergency Services"@en,
                                          "Disaster emergency relief"@en;
                            skos:broader :Cause;
                            skos:definition "Volunteering in emergency response, disaster relief, humanitarian aid, and crisis management."@en;
                            skos:prefLabel "Development & emergency relief"@en.
:DigitalAccessibility a skos:Concept;
                      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                      skos:broader :Accessibility;
                      skos:definition "Any accessbility information regarding digital requirements for an activity"@en;
                      skos:inScheme :Taxonomy;
                      skos:prefLabel "Digital Accessibility"@en.
:DigitalAndTechnology a skos:Concept;
                      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                      skos:broader :Skill;
                      skos:definition "Skills related to digital tools, technology, and IT in volunteering contexts."@en;
                      skos:prefLabel "Digital & technology"@en.
:Disability a skos:Concept;
            rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
            skos:altLabel "Impairment"@en,
                          "Diabled Groups"@en,
                          "Disabled People"@en;
            skos:broader :Cause;
            skos:definition "Volunteering supporting people with disabilities, accessibility advocacy, and disability services."@en;
            skos:prefLabel "Disability"@en.
:DiverseNeedsAwareness a skos:Concept;
                       rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                       skos:broader :CommunityEnvironmentKnowledge;
                       skos:prefLabel "Understanding diverse needs within the community"@en.
:Driving a skos:Concept;
         rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
         skos:broader :PracticalAndOperational;
         skos:definition "Ability to drive cars, vans, or off-road vehicles."@en;
         skos:prefLabel "Driving (car, van, off-road vehicles)"@en.
:EducationLanguages a skos:Concept;
                    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                    skos:altLabel "Dialects"@en,
                                  "Tongues"@en,
                                  "Further Education"@en,
                                  "Schooling"@en;
                    skos:broader :Cause;
                    skos:definition "Volunteering in education programmes, language support, literacy, and educational development."@en;
                    skos:prefLabel "Education & languages"@en.
:EmergencyBriefings a skos:Concept;
                    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                    skos:broader :SafetyAndEmergencyAwareness;
                    skos:definition "Ability to understand and follow emergency briefings and instructions."@en;
                    skos:prefLabel "Understanding emergency briefings and instructions"@en.
:EmpathyAndCompassion a skos:Concept;
                      rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                      skos:broader :PersonalAndInterpersonal;
                      skos:definition "Ability to understand and share the feelings of others with care and concern."@en;
                      skos:prefLabel "Empathy and compassion"@en.
:Environment a skos:Concept;
             rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
             skos:altLabel "Sustainability"@en,
                           "Clean"@en,
                           "Atmosphere"@en,
                           "Climate Change"@en,
                           "Ecosystem"@en,
                           "Natural Environment"@en,
                           "Conservation"@en,
                           "Planet"@en,
                           "Nature"@en,
                           "Surroundings"@en,
                           "Natural World"@en;
             skos:broader :Cause;
             skos:definition "Volunteering addressing environmental conservation, climate change, sustainability, and natural resource protection."@en;
             skos:prefLabel "Environment"@en.
:EthnicMinorities a skos:Concept;
                  rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                  skos:altLabel "Racial Groups"@en,
                                "Racial Minorities"@en,
                                "Ethnic Communities"@en,
                                "Ethnic Groups"@en;
                  skos:broader :Cause;
                  skos:definition "Volunteering supporting ethnic minority groups, racial equality, and cultural integration."@en;
                  skos:prefLabel "Ethnic Minorities"@en.
:ExpensesPaid a skos:Concept;
              rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
              skos:broader :Accessibility;
              skos:definition "Any information regarding reimbursement for activity or role-related expenses.";
              skos:inScheme :Taxonomy;
              skos:prefLabel "Expenses Paid".
:Families a skos:Concept;
          rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
          skos:altLabel "Loved Ones"@en,
                        "Family Members"@en,
                        "Households"@en,
                        "Relatives"@en;
          skos:broader :Cause;
          skos:definition "Volunteering supporting families, household welfare, and family services."@en;
          skos:prefLabel "Families"@en.
:FireSafetyAwareness a skos:Concept;
                     rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                     skos:broader :SafetyAndEmergencyAwareness;
                     skos:definition "Awareness of fire safety procedures and prevention measures."@en;
                     skos:prefLabel "Fire safety awareness"@en.
:FirstAidKit a skos:Concept;
             rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
             skos:broader :PersonalEquipment;
             skos:prefLabel "Small personal first aid kit"@en.
:FourByFourVehicle a skos:Concept;
                   rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                   skos:broader :TransportMobilityAssets;
                   skos:prefLabel "4x4 vehicle (personal or organisational)"@en.
:FridayAfternoon a :WeekdayTimePeriod,
                   :Time,
                   time:TemporalEntity;
                 rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
                 rdfs:label "Friday afternoon"@en;
                 time:hasBeginning [a time:Instant ; 
                                    time:inDateTime [a time:GeneralDateTimeDescription ; 
                                                     time:dayOfWeek time:Friday ; 
                                                     time:hour "12"^^xsd:nonNegativeInteger ; 
                                                     time:minute "0"^^xsd:nonNegativeInteger ; 
                                                     time:second "0"^^xsd:nonNegativeInteger]];
                 time:hasEnd [a time:Instant ; 
                              time:inDateTime [a time:GeneralDateTimeDescription ; 
                                               time:dayOfWeek time:Friday ; 
                                               time:hour "18"^^xsd:nonNegativeInteger ; 
                                               time:minute "0"^^xsd:nonNegativeInteger ; 
                                               time:second "0"^^xsd:nonNegativeInteger]].
:FridayEvening a :WeekdayTimePeriod,
                 :Time,
                 time:TemporalEntity;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               rdfs:label "Friday evening"@en;
               time:hasBeginning [a time:Instant ; 
                                  time:inDateTime [a time:GeneralDateTimeDescription ; 
                                                   time:dayOfWeek time:Friday ; 
                                                   time:hour "18"^^xsd:nonNegativeInteger ; 
                                                   time:minute "0"^^xsd:nonNegativeInteger ; 
                                                   time:second "0"^^xsd:nonNegativeInteger]];
               time:hasEnd [a time:Instant ; 
                            time:inDateTime [a time:GeneralDateTimeDescription ; 
                                             time:dayOfWeek time:Friday ; 
                                             time:hour "24"^^xsd:nonNegativeInteger ; 
                                             time:minute "0"^^xsd:nonNegativeInteger ; 
                                             time:second "0"^^xsd:nonNegativeInteger]].
:FridayMorning a :WeekdayTimePeriod,
                 :Time,
                 time:TemporalEntity;
               rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
               rdfs:label "Friday morning"@en;
               time:hasBeginning [a time:Instant ; 
                                  time:inDateTime [a time:GeneralDateTimeDescription ; 
                                                   time:dayOfWeek time:Friday ; 
                                                   time:hour "6"^^xsd:nonNegativeInteger ; 
                                                   time:minute "0"^^xsd:nonNegativeInteger ; 
                                                   time:second "0"^^xsd:nonNegativeInteger]];
               time:hasEnd [a time:Instant ; 
                            time:inDateTime [a time:GeneralDateTimeDescription ; 
                                             time:dayOfWeek time:Friday ; 
                                             time:hour "12"^^xsd:nonNegativeInteger ; 
                                             time:minute "0"^^xsd:nonNegativeInteger ; 
                                             time:second "0"^^xsd:nonNegativeInteger]].
