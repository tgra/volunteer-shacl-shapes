volunteer-shape:Activity sh:type sh:NodeShape;
    rdfs:label "Activity";
    sh:codeIdentifier "VolunteerActivity";
    a sh:NodeShape, rdfs:Class;
    sh:property volunteer-shape:activityHasDescription, volunteer-shape:activityHasRole, volunteer-shape:activityRequiresEmergencyParticipation, volunteer-shape:activityHasTitle, volunteer-shape:activityHasImage, volunteer-shape:activityHasOrganisation, volunteer-shape:activityHasSession
