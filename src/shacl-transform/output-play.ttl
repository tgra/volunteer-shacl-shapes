.
volunteer-shape:Organisation sh:type sh:NodeShape;
    rdfs:label "Organisation";
    sh:codeIdentifier "VolunteerOrganisation";
    a rdfs:Class, sh:NodeShape;
    sh:property volunteer-shape:organisationHasCharityNumber, volunteer-shape:organisationHasImage, volunteer-shape:organisationHasWebsite, volunteer-shape:organisationHasCharitableCause, volunteer-shape:organisationHasName, volunteer-shape:organisationHasActivity, volunteer-shape:organisationHasDescription
