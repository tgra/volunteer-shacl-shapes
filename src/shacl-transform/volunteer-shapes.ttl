volunteer-shapes:LocationShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "Any location related to volunteering activities."@en;
    sh:name "Location"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:SessionHasLocation;
    sh:targetClass :Location;
    sh:codeIdentifier "Location".

volunteer-shapes:OrganisationShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "Any organisation running activities that involve volunteers."@en;
    sh:name "Organisation"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:OrganisationHasCharitableCause, volunteer-shapes:OrganisationHasActivity;
    sh:targetClass :Organisation;
    sh:codeIdentifier "Organisation".

volunteer-shapes:RoleShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "Any kind of role related to a volunteering activity."@en;
    sh:name "Role"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:RoleHasRequirement, volunteer-shapes:RoleHasActivity, volunteer-shapes:RoleAllowsRemoteParticipation, volunteer-shapes:RoleHasReward, volunteer-shapes:RoleHasSkill, volunteer-shapes:RoleHasAccessibility;
    sh:targetClass :Role;
    sh:codeIdentifier "Role".

volunteer-shapes:ActivityShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "Any kind of activity that involves volunteers."@en;
    sh:name "Activity"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:ActivityHasSession, volunteer-shapes:ActivityRequiresEmergencyParticipation, volunteer-shapes:ActivityHasOrganisation, volunteer-shapes:ActivityHasRole;
    sh:targetClass :Activity;
    sh:codeIdentifier "Activity".

volunteer-shapes:WeekdayTimePeriodShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "A predefined time period within a specific day of the week (morning, afternoon or evening)."@en;
    sh:name "Weekday Time Period"@en;
    sh:nodeKind sh:IRI;
    sh:targetClass :WeekdayTimePeriod;
    sh:codeIdentifier "WeekdayTimePeriod".

volunteer-shapes:TimeShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "Any time information related to volunteering activities modeled as a OWL time temporal entity."@en;
    sh:name "Time"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:TimeHasSession;
    sh:targetClass :Time;
    sh:codeIdentifier "Time".

volunteer-shapes:SessionShape a sh:NodeShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:description "A session describes a time and place for an activity that involves volunteers."@en;
    sh:name "Session"@en;
    sh:nodeKind sh:IRI;
    sh:property volunteer-shapes:SessionHasLocation, volunteer-shapes:SessionHasActivity, volunteer-shapes:SessionHasTime;
    sh:targetClass :Session;
    sh:codeIdentifier "Session".
