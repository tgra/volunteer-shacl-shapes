volunteer-shapes:ActivityRequiresEmergencyParticipation a sh:PropertyShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:datatype xsd:boolean;
    sh:name "activity requires emergency participation"@en;
    sh:nodeKind sh:Literal;
    sh:path :activityRequiresEmergencyParticipation;
    sh:pattern "true|false|0|1";
    sh:codeIdentifier "ActivityRequiresEmergencyParticipation".

