volunteer-shapes:AccessibilityInformationHasRole a sh:PropertyShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
    sh:class :Role;
    sh:name "accessibility information has role"@en;
    sh:nodeKind sh:BlankNodeOrIRI;
    sh:path :accessibilityRole;
    sh:codeIdentifier "AccessibilityInformationHasRole".

volunteer-shapes:RewardHasRole a sh:PropertyShape;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/>;
